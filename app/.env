# AI Provider Configuration - Choose ONE provider below
# 
# Provider Options:
# 1. FIREWORKS: Fastest inference, supports temperature 0.7-1.0
#    - Endpoint: https://api.fireworks.ai/inference/v1
#    - Model: accounts/fireworks/models/llama-v3p1-70b-instruct
# 2. DEEPINFRA: Good balance of speed and cost
#    - Endpoint: https://api.deepinfra.com/v1/inference
#    - Model: meta-llama/Meta-Llama-3.1-70B-Instruct
# 3. KIMI (default): Requires temperature=1.0, slower inference
#    - Endpoint: https://api.moonshot.cn/v1
#    - Model: kimi-k2.5

# ==== FIREWORKS (Recommended for speed) ====
# VITE_AI_API_KEY=fw-xxxxxxxxxxxxxxxxxxxxxxxx
# VITE_AI_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
# VITE_AI_BASE_URL=https://api.fireworks.ai/inference/v1

# ==== DEEPINFRA ====
# VITE_AI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# VITE_AI_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# VITE_AI_BASE_URL=https://api.deepinfra.com/v1/openai

# ==== KIMI (Current - requires temperature=1.0) ====
VITE_AI_API_KEY=sk-Qu6ykuJb7Gkg7nIphRopj9IMRjnZI8GKTuneWiaXeb9kO6kH
VITE_AI_MODEL=kimi-k2.5
VITE_AI_BASE_URL=http://localhost:3001/api
VITE_AI_APP_ID=ak-f8me838r8yq111ejdbd1

# Legacy Kimi config (for backward compatibility)
VITE_KIMI_APP_ID=ak-f8me838r8yq111ejdbd1
VITE_KIMI_API_KEY=sk-Qu6ykuJb7Gkg7nIphRopj9IMRjnZI8GKTuneWiaXeb9kO6kH
VITE_KIMI_MODEL=kimi-k2.5

# Proxy Server URL (bypasses CORS)
VITE_KIMI_API_URL=http://localhost:3001/api

# Performance Settings
VITE_AI_TEMPERATURE=1.0
VITE_AI_CACHE_TTL_MINUTES=10
VITE_LOG_TOKEN_USAGE=true

# Streaming Mode
# Set to 'false' to disable streaming (may reduce 429 rate limit errors)
# When disabled, content is generated all at once (slower but more reliable)
VITE_USE_STREAMING=true
